  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6F8797",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#69B7A5"
      }
    },
    {
      "name": "String Interpolation",
      "scope": [
        "punctuation.section.embedded",
        "meta.embedded",
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#F0F6F3"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8D7DB8"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#8D7DB8"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
