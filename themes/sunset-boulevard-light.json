  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#847A72",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#64856F"
      }
    },
    {
      "name": "String Interpolation",
      "scope": [
        "punctuation.section.embedded",
        "meta.embedded",
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#37414D"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8C72A0"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#8C72A0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#8C72A0"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D89253",
        "fontStyle": "bold"
