    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#4F4D40"
      }
    },
    {
      "name": "Function Definition",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
