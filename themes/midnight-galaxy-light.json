  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A7394",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#4F9E80"
      }
    },
    {
      "name": "String Interpolation",
      "scope": [
        "punctuation.section.embedded",
        "meta.embedded",
        "variable.interpolation"
      ],
      "settings": {
        "foreground": "#2E2940"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8A6FD4"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#8A6FD4"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#8A6FD4"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C07A4B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword Control",
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#C07A4B",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#5D5770"
      }
    },
    {
      "name": "Function Definition",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#5B79D8"
      }
    },
    {
      "name": "Method Call",
      "scope": [
        "meta.method-call",
        "meta.function-call variable.function"
      ],
      "settings": {
        "foreground": "#5B79D8"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#725CC8",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type"
